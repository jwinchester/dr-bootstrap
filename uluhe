#!/usr/bin/env bash
# uluhe — operator CLI for failover, status, and surge capacity
#
# Subcommands:
#   uluhe status                      # health check on current primary
#   uluhe switch <vendor> [--test]    # provision new primary on hetzner|do|oracle
#   uluhe surge --job <name> --days N # quote burst-capacity machine
#   uluhe --hold                      # cancel a pending auto-failover (5min window)
#
# Skeleton: most subcommands are stubs that print intent, not action.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PRIMARY_HOST="${ULUHE_PRIMARY:-hetz-1}"
PRIMARY_SSH_USER="${ULUHE_SSH_USER:-uluhe}"
ROOT_SSH_USER="${ULUHE_ROOT_SSH_USER:-root}"

# Colors only when stdout is a TTY
if [ -t 1 ]; then
  C_OK=$'\033[32m'; C_WARN=$'\033[33m'; C_BAD=$'\033[31m'; C_DIM=$'\033[2m'; C_RST=$'\033[0m'
else
  C_OK=""; C_WARN=""; C_BAD=""; C_DIM=""; C_RST=""
fi

check_label() { printf "  %-32s " "$1"; }
ok()    { printf "${C_OK}OK${C_RST}    %s\n" "${1:-}"; }
warn()  { printf "${C_WARN}WARN${C_RST}  %s\n" "${1:-}"; }
bad()   { printf "${C_BAD}FAIL${C_RST}  %s\n" "${1:-}"; }
note()  { printf "${C_DIM}note${C_RST}  %s\n" "${1:-}"; }

cmd_status() {
  echo "uluhe status — primary=${PRIMARY_HOST}"
  echo

  # 1. Reachability via Tailscale SSH
  check_label "ssh reach (${PRIMARY_SSH_USER}@${PRIMARY_HOST})"
  if ssh -o BatchMode=yes -o ConnectTimeout=5 "${PRIMARY_SSH_USER}@${PRIMARY_HOST}" true 2>/dev/null; then
    ok
  else
    bad "primary unreachable; remaining checks aborted"
    return 1
  fi

  # Pull a single snapshot of host state in one SSH round-trip
  local probe
  probe=$(ssh -o BatchMode=yes -o ConnectTimeout=8 "${PRIMARY_SSH_USER}@${PRIMARY_HOST}" '
    set +e
    echo "HOST_DATE=$(date -u +%s)"
    echo "UPTIME=$(awk "{print \$1}" /proc/uptime)"
    echo "DISK_PCT=$(df -P /home/uluhe | awk "NR==2{gsub(/%/,\"\",\$5); print \$5}")"
    echo "DISK_FREE=$(df -hP /home/uluhe | awk "NR==2{print \$4}")"
    echo "MEM_PCT=$(awk "/MemTotal/{t=\$2}/MemAvailable/{a=\$2}END{printf \"%d\", (t-a)*100/t}" /proc/meminfo)"
    echo "LOAD_1M=$(awk "{print \$1}" /proc/loadavg)"
    echo "TAILSCALE=$(systemctl is-active tailscaled 2>/dev/null || echo unknown)"
    echo "SYNCTHING=$(systemctl is-active syncthing@uluhe.service 2>/dev/null || echo unknown)"
    echo "JOPPA_AGENT=$(systemctl is-active joppa-agent.service 2>/dev/null || echo unknown)"
    echo "RESTIC_TIMER=$(systemctl is-active restic-backup.timer 2>/dev/null || echo unknown)"
    echo "RESTIC_FORGET_TIMER=$(systemctl is-active restic-forget.timer 2>/dev/null || echo unknown)"
    echo "LIBRARY_INTAKE=$(systemctl is-active library-intake.service 2>/dev/null || echo unknown)"
    # Most recent restic-backup.service finish time + result (needs sudo for system journal)
    rb=$(sudo -n journalctl -u restic-backup.service -o short-unix --no-pager 2>/dev/null \
         | grep -E "Finished|Failed with result" | tail -1)
    echo "RESTIC_LAST=${rb:-none}"
    # Joppa-agent recent restart count (last hour)
    ja_restarts=$(sudo -n journalctl -u joppa-agent.service --since "1 hour ago" --no-pager 2>/dev/null \
                 | grep -c "systemd\[1\]: Started" )
    echo "JOPPA_AGENT_RESTARTS_1H=${ja_restarts}"
    echo "LOTOR_TIMER=$(systemctl is-active lotor.timer 2>/dev/null || echo unknown)"
    if [ -f /home/uluhe/.lotor/state.json ]; then
      echo "LOTOR_LAST_RUN=$(python3 -c "import json; print(json.load(open(\"/home/uluhe/.lotor/state.json\")).get(\"last_run_ts\",0))" 2>/dev/null || echo 0)"
    else
      echo "LOTOR_LAST_RUN=0"
    fi
  ' 2>/dev/null)

  # parse into shell vars
  while IFS='=' read -r k v; do
    [ -z "$k" ] && continue
    eval "P_${k}=\"\$v\""
  done <<< "$probe"

  # 2. Tailscale daemon
  check_label "tailscaled"
  case "${P_TAILSCALE:-}" in
    active) ok ;;
    *) bad "${P_TAILSCALE:-no-data}" ;;
  esac

  # 3. Syncthing daemon
  check_label "syncthing@uluhe"
  case "${P_SYNCTHING:-}" in
    active) ok ;;
    *) bad "${P_SYNCTHING:-no-data}" ;;
  esac

  # 4. Joppa exec bot
  check_label "joppa-agent.service"
  case "${P_JOPPA_AGENT:-}" in
    active)
      if [ "${P_JOPPA_AGENT_RESTARTS_1H:-0}" -gt 3 ]; then
        warn "active but ${P_JOPPA_AGENT_RESTARTS_1H} restarts in last hour"
      else
        ok
      fi
      ;;
    *) bad "${P_JOPPA_AGENT:-no-data}" ;;
  esac

  # 5. Library-intake
  check_label "library-intake"
  case "${P_LIBRARY_INTAKE:-}" in
    active) ok ;;
    inactive|unknown) note "${P_LIBRARY_INTAKE:-no-data} (optional)" ;;
    *) warn "${P_LIBRARY_INTAKE}" ;;
  esac

  # 6. Restic timers
  check_label "restic-backup.timer (15m)"
  case "${P_RESTIC_TIMER:-}" in
    active) ok ;;
    inactive) warn "paused — investigate before relying on backups" ;;
    *) bad "${P_RESTIC_TIMER:-no-data}" ;;
  esac
  check_label "restic-forget.timer (daily)"
  case "${P_RESTIC_FORGET_TIMER:-}" in
    active) ok ;;
    *) warn "${P_RESTIC_FORGET_TIMER:-no-data}" ;;
  esac

  # 7. Restic last run
  check_label "restic last backup"
  if [ -n "${P_RESTIC_LAST:-}" ] && [ "${P_RESTIC_LAST}" != "none" ]; then
    local ts result
    ts=$(echo "${P_RESTIC_LAST}" | awk '{print $1}' | cut -d. -f1)
    if echo "${P_RESTIC_LAST}" | grep -q "Failed with result"; then
      result="FAILED"
    else
      result="ok"
    fi
    if [ -n "$ts" ] && [ "$ts" != "0" ]; then
      local now age_min
      now=$(date -u +%s)
      age_min=$(( (now - ts) / 60 ))
      if [ "$result" = "FAILED" ]; then
        bad "last attempt ${age_min}m ago: FAILED"
      elif [ "$age_min" -gt 30 ]; then
        warn "${age_min}m ago (>30m threshold)"
      else
        ok "${age_min}m ago"
      fi
    else
      warn "couldn't parse timestamp"
    fi
  else
    warn "no restic-backup runs in journal"
  fi

  # 8. Disk
  check_label "disk /home/uluhe"
  if [ -n "${P_DISK_PCT:-}" ]; then
    if [ "${P_DISK_PCT}" -ge 90 ]; then
      bad "${P_DISK_PCT}% used (free ${P_DISK_FREE})"
    elif [ "${P_DISK_PCT}" -ge 80 ]; then
      warn "${P_DISK_PCT}% used (free ${P_DISK_FREE})"
    else
      ok "${P_DISK_PCT}% used (free ${P_DISK_FREE})"
    fi
  else
    warn "no data"
  fi

  # 9. Memory + load (informational)
  check_label "mem / load"
  if [ -n "${P_MEM_PCT:-}" ]; then
    note "mem ${P_MEM_PCT}% used, 1m load ${P_LOAD_1M:-?}"
  fi

  # 10. Uptime (show hours under 24h, else days)
  check_label "uptime"
  if [ -n "${P_UPTIME:-}" ]; then
    local up
    up=$(awk -v u="${P_UPTIME}" 'BEGIN{
      if (u < 86400) printf "%.1fh", u/3600
      else printf "%.1f days", u/86400
    }')
    note "${up}"
  fi

  # 11. Lotor heartbeat
  check_label "lotor.timer + heartbeat"
  case "${P_LOTOR_TIMER:-}" in
    active)
      if [ -n "${P_LOTOR_LAST_RUN:-}" ] && [ "${P_LOTOR_LAST_RUN}" != "0" ]; then
        local now lotor_age_min
        now=$(date -u +%s)
        lotor_age_min=$(( (now - P_LOTOR_LAST_RUN) / 60 ))
        if [ "$lotor_age_min" -gt 30 ]; then
          warn "timer active but last run ${lotor_age_min}m ago (>30m — daemon may be stuck)"
        else
          ok "last run ${lotor_age_min}m ago"
        fi
      else
        warn "timer active but no state file yet (first run pending?)"
      fi
      ;;
    inactive) note "not deployed (lotor v0 not enabled here)" ;;
    *) note "${P_LOTOR_TIMER:-no-data}" ;;
  esac

  echo
}

# orchestrate_phase1 — drive secrets-fetch + setup.sh phase1 over SSH against
# a freshly-provisioned VM. Called from cmd_switch after terraform apply.
#
# Flow:
#   1. Wait for sshd; wait for cloud-init to finish (cloud-init status --wait)
#   2. Locally decrypt b2-keys.enc → extract `secrets-uluhe` keyID + applicationKey
#      (passphrase prompt #1 of 2)
#   3. scp scripts/fetch-secrets-from-b2.sh to VM, run it with B2 creds piped
#      via stdin (never on command line, never persisted)
#   4. ssh -t for setup.sh phase1 — operator types passphrase at the VM-side
#      age prompt (passphrase prompt #2 of 2; same passphrase, different sides)
#   5. Report exit; on failure, stream tail of /var/log/joppa-setup.log
#
# Args: $1=ipv4, $2=hostname, $3=test_mode (0|1)
# Uses operator's wallypad SSH key (uploaded to Hetzner project as "wallypad");
# sshd on Hetzner public IPv4 is reachable before Tailscale converges.
orchestrate_phase1() {
  local ipv4="$1" hostname="$2" test_mode="${3:-0}"

  echo
  echo "================ orchestrate phase1 ================"
  echo "  Target:    root@${ipv4}  (hostname=${hostname})"
  echo "===================================================="
  echo

  # ---- Step 1: wait for sshd + cloud-init ----
  echo "[orch 1/4] waiting for sshd on ${ipv4} (up to ~2min)…"
  local i sshok=0
  for i in $(seq 1 30); do
    if ssh -o ConnectTimeout=5 \
           -o StrictHostKeyChecking=accept-new \
           -o UserKnownHostsFile=/dev/null \
           -o BatchMode=yes \
           "root@${ipv4}" 'true' 2>/dev/null; then
      sshok=1; break
    fi
    printf "."; sleep 4
  done
  echo
  if [ "$sshok" = 0 ]; then
    echo "ERROR: sshd unreachable on ${ipv4} after ~2min" >&2
    return 1
  fi
  ok "sshd reachable"

  echo "[orch 2/4] waiting for cloud-init to finish (this is the apt-update + tailscale-install + git-clone leg; max 10min)…"
  if ! timeout 600 ssh -o StrictHostKeyChecking=accept-new \
           -o UserKnownHostsFile=/dev/null \
           "root@${ipv4}" 'cloud-init status --wait'; then
    echo "ERROR: cloud-init failed or timed out on ${ipv4}" >&2
    echo "  Inspect: ssh root@${ipv4} 'cat /var/log/cloud-init-output.log'" >&2
    return 1
  fi
  ok "cloud-init complete"

  # ---- Step 2: extract B2 secrets-uluhe creds locally ----
  echo "[orch 3/4] extracting B2 secrets-uluhe key from local b2-keys.enc"
  echo "  (you will be prompted for the age passphrase — 1st of 2 prompts)"

  local SECRETS_DIR_LOCAL="${REPO_DIR}/../secrets"
  local AGE_KEY_ENC_LOCAL="${HOME}/.config/dr/age-key.enc"
  local B2_KEYS_ENC="${SECRETS_DIR_LOCAL}/b2-keys.enc"
  local FETCH_SCRIPT="${REPO_DIR}/../scripts/fetch-secrets-from-b2.sh"

  [ -f "$AGE_KEY_ENC_LOCAL" ] || { echo "ERROR: missing $AGE_KEY_ENC_LOCAL" >&2; return 1; }
  [ -f "$B2_KEYS_ENC" ]       || { echo "ERROR: missing $B2_KEYS_ENC" >&2; return 1; }
  [ -f "$FETCH_SCRIPT" ]      || { echo "ERROR: missing $FETCH_SCRIPT" >&2; return 1; }

  local TMPDIR_ORCH
  TMPDIR_ORCH="$(mktemp -d -t uluhe-orch-XXXXXX)"
  chmod 700 "$TMPDIR_ORCH"
  # Local cleanup trap (overrides any earlier RETURN trap on this function).
  # shellcheck disable=SC2064
  trap "find '$TMPDIR_ORCH' -type f -exec shred -u {} \\; 2>/dev/null; rm -rf '$TMPDIR_ORCH'" RETURN

  if ! age -d -o "$TMPDIR_ORCH/id" "$AGE_KEY_ENC_LOCAL"; then
    echo "ERROR: age identity decrypt failed (wrong passphrase?)" >&2
    return 1
  fi
  if ! age -d -i "$TMPDIR_ORCH/id" -o "$TMPDIR_ORCH/b2-keys.txt" "$B2_KEYS_ENC"; then
    echo "ERROR: b2-keys.enc decrypt failed" >&2
    return 1
  fi

  local b2_id b2_key
  # `|| true` so that a python parser failure (which writes to stderr but no
  # stdout) doesn't trigger set -e before the empty-cred guard below runs.
  read -r b2_id b2_key < <(python3 - "$TMPDIR_ORCH/b2-keys.txt" <<'PY'
import sys
src = sys.argv[1]
LABELS = {"keyID","keyName","applicationKey"}
lines = [ln.rstrip("\n") for ln in open(src)]
entries, cur, i = [], {}, 0
while i < len(lines):
    s = lines[i].strip()
    if not s:
        if cur: entries.append(cur); cur = {}
        i += 1; continue
    if s.endswith(":") and s[:-1] in LABELS:
        label = s[:-1]
        j = i + 1
        while j < len(lines) and not lines[j].strip(): j += 1
        if j < len(lines):
            if label in cur: entries.append(cur); cur = {}
            cur[label] = lines[j].strip()
        i = j + 1
    else:
        i += 1
if cur: entries.append(cur)
target = next((e for e in entries if e.get("keyName") == "secrets-uluhe"), None)
if not target:
    sys.stderr.write("FAIL: secrets-uluhe not in b2-keys.enc; available: " +
        ", ".join(repr(e.get("keyName")) for e in entries) + "\n")
    sys.exit(1)
print(target["keyID"], target["applicationKey"])
PY
  ) || true
  if [ -z "$b2_id" ] || [ -z "$b2_key" ]; then
    echo "ERROR: secrets-uluhe creds not extracted" >&2
    return 1
  fi
  ok "secrets-uluhe extracted (id prefix: ${b2_id:0:8}…)"

  # ---- Step 3: copy fetch script + run on VM with creds via stdin ----
  echo "[orch 4/4] copying fetch-secrets-from-b2.sh to VM and running it"

  if ! ssh -o StrictHostKeyChecking=accept-new \
            -o UserKnownHostsFile=/dev/null \
            "root@${ipv4}" \
            'mkdir -p /opt/dr-bootstrap/scripts /opt/dr-bootstrap/secrets && chmod 700 /opt/dr-bootstrap/secrets'; then
    echo "ERROR: dir create on VM failed" >&2; return 1
  fi
  if ! scp -o StrictHostKeyChecking=accept-new \
            -o UserKnownHostsFile=/dev/null \
            "$FETCH_SCRIPT" "root@${ipv4}:/opt/dr-bootstrap/scripts/fetch-secrets-from-b2.sh"; then
    echo "ERROR: scp fetch-secrets-from-b2.sh failed" >&2; return 1
  fi
  ssh -o StrictHostKeyChecking=accept-new \
      -o UserKnownHostsFile=/dev/null \
      "root@${ipv4}" 'chmod +x /opt/dr-bootstrap/scripts/fetch-secrets-from-b2.sh'

  # Overwrite the cloud-init-cloned setup.sh with the local working copy.
  # Lets us iterate setup.sh without needing a github push between attempts;
  # the source-of-truth in dr-bootstrap repo can lag during fire-drills.
  local LOCAL_SETUP="${REPO_DIR}/bootstrap/setup.sh"
  if [ -f "$LOCAL_SETUP" ]; then
    if ! scp -o StrictHostKeyChecking=accept-new \
              -o UserKnownHostsFile=/dev/null \
              "$LOCAL_SETUP" "root@${ipv4}:/opt/dr-bootstrap/bootstrap/setup.sh"; then
      echo "ERROR: scp setup.sh failed" >&2; return 1
    fi
    ok "setup.sh: local working copy synced (overrides cloned version)"
  fi

  # Pipe B2 creds via stdin → remote shell `read`s into env vars → script invoked.
  # Never on command line, never to disk. Vars die when the remote shell exits.
  if ! ssh -o StrictHostKeyChecking=accept-new \
           -o UserKnownHostsFile=/dev/null \
           "root@${ipv4}" '
             set -e
             read -r B2_SECRETS_KEY_ID
             read -r B2_SECRETS_KEY
             export B2_SECRETS_KEY_ID B2_SECRETS_KEY
             bash /opt/dr-bootstrap/scripts/fetch-secrets-from-b2.sh
           ' <<EOF
$b2_id
$b2_key
EOF
  then
    echo "ERROR: fetch-secrets-from-b2.sh on VM failed" >&2; return 1
  fi
  unset b2_id b2_key
  ok "secrets/*.enc fetched onto VM (/opt/dr-bootstrap/secrets/)"

  # ---- Step 4: drive setup.sh phase1 with PTY for age passphrase prompt ----
  echo
  echo "================ setup.sh phase1 ================"
  echo "  Operator: type the age passphrase when prompted (2nd of 2)."
  echo "  phase1 runs: materialize_secrets → restic restore latest → /"
  echo "             → rebuild_joppa_bots_runtime → enable timers + services"
  echo "  Expected duration: 3-5 min (restic restore is the dominant term)."
  echo "================================================="
  echo

  # In test mode, set SKIP_ENABLE=1 so phase1 doesn't bring services online
  # (would collide with hetz-1's bot token + restic repo + lotor alerts).
  local skip_enable_arg=""
  if [ "$test_mode" = 1 ]; then
    skip_enable_arg="SKIP_ENABLE=1 "
    echo "  (test mode: SKIP_ENABLE=1 — units restored but not enabled, to avoid hetz-1 collision)"
  fi

  local phase1_rc=0
  ssh -t -o StrictHostKeyChecking=accept-new \
         -o UserKnownHostsFile=/dev/null \
         "root@${ipv4}" "cd /opt/dr-bootstrap && ${skip_enable_arg}bash bootstrap/setup.sh phase1" \
    || phase1_rc=$?

  if [ "$phase1_rc" -ne 0 ]; then
    echo
    echo "ERROR: setup.sh phase1 exited rc=${phase1_rc}. Last 40 log lines:" >&2
    ssh "root@${ipv4}" 'tail -40 /var/log/joppa-setup.log 2>/dev/null || echo "(no log)"' >&2 || true
    return "$phase1_rc"
  fi

  echo
  ok "phase1 complete on ${hostname}"
  echo
  echo "Verify:  ULUHE_PRIMARY=${hostname} ./uluhe status"
  if [ "$test_mode" = 1 ]; then
    echo "Tear down:  ./uluhe switch hetzner --destroy"
  fi
}

cmd_switch() {
  local vendor="$1"; shift || true
  local test_mode=0
  local destroy=0
  local skip_confirm=0
  local orchestrate=1   # default-on; set to 0 with --no-orchestrate for bare-provision debugging
  for arg in "$@"; do
    case "$arg" in
      --test)            test_mode=1 ;;
      --destroy)         destroy=1 ;;
      --yes)             skip_confirm=1 ;;
      --no-orchestrate)  orchestrate=0 ;;
      *) echo "WARN: unknown switch arg: $arg" >&2 ;;
    esac
  done

  case "$vendor" in
    hetzner) ;;
    do|oracle) echo "ERROR: vendor $vendor not yet wired (only hetzner ready 2026-04-30)" >&2; exit 1 ;;
    *) echo "ERROR: vendor must be hetzner|do|oracle" >&2; exit 1 ;;
  esac

  # Locate terraform binary
  local TF
  TF="$(command -v terraform 2>/dev/null || echo "$HOME/bin/terraform")"
  [ -x "$TF" ] || { echo "ERROR: terraform not found (tried PATH and ~/bin/terraform)" >&2; exit 1; }

  # Source the Hetzner token from existing local cli.toml
  # (DR path: setup.sh::materialize_secrets writes /etc/hcloud/cli.toml on a
  #  fresh VM. Operator wallypad already has the plaintext at ~/.config/hcloud.)
  local CLI_TOML="$HOME/.config/hcloud/cli.toml"
  [ -f "$CLI_TOML" ] || { echo "ERROR: no Hetzner token at $CLI_TOML — materialize from secrets first" >&2; exit 1; }
  HCLOUD_TOKEN="$(awk -F'"' '/^[[:space:]]*token *=/{print $2; exit}' "$CLI_TOML")"
  [ -n "$HCLOUD_TOKEN" ] || { echo "ERROR: couldn't extract token from $CLI_TOML" >&2; exit 1; }
  export HCLOUD_TOKEN

  local TF_DIR="$REPO_DIR/terraform"
  cd "$TF_DIR" || { echo "ERROR: terraform dir missing at $TF_DIR" >&2; exit 1; }

  # ---- Destroy path ----
  if [ "$destroy" = 1 ]; then
    echo "uluhe switch $vendor --destroy"
    echo
    "$TF" show -no-color 2>/dev/null | grep -E "^# hcloud_server\." || {
      echo "(nothing in state to destroy — already clean)"
      return 0
    }
    if [ "$skip_confirm" = 0 ]; then
      printf "Confirm destroy? (yes/no) "
      read -r confirm
      [ "$confirm" = "yes" ] || { echo "aborted"; return 1; }
    fi
    "$TF" destroy -auto-approve -var=vm_hostname=ignored
    return $?
  fi

  # ---- Apply path ----
  local default_hostname
  if [ "$test_mode" = 1 ]; then
    default_hostname="hetz-test"
  else
    default_hostname="hetz-$(date +%Y%m%d)"
  fi

  printf "VM hostname [%s]: " "$default_hostname"
  read -r VM_HOSTNAME
  VM_HOSTNAME="${VM_HOSTNAME:-$default_hostname}"

  echo "Tailscale single-use auth key (paste; input hidden):"
  echo "  Mint at https://login.tailscale.com/admin/settings/keys"
  printf "Key: "
  read -rs TS_AUTH_KEY
  echo
  [ -n "$TS_AUTH_KEY" ] || { echo "ERROR: tailscale auth key required" >&2; exit 1; }

  echo
  echo "Will provision Hetzner VM:"
  echo "  hostname:    $VM_HOSTNAME"
  echo "  type:        cax31 (4 vCPU ARM / 8 GB / 160 GB / €14/mo)"
  echo "  region:      hel1 (Helsinki)"
  echo "  test mode:   $test_mode"
  echo
  if [ "$test_mode" = 1 ]; then
    echo "TEST MODE — VM will boot to verify the provisioning chain. Tear down with:"
    echo "  ./uluhe switch hetzner --destroy"
  else
    echo "REAL FAILOVER — VM stays up. Standing cost: ~€14/mo from creation."
  fi
  echo

  if [ "$skip_confirm" = 0 ]; then
    printf "Proceed? (yes/no) "
    read -r confirm
    [ "$confirm" = "yes" ] || { echo "aborted"; return 1; }
  fi

  echo
  echo "[1/3] terraform init"
  "$TF" init -upgrade -no-color || { echo "ERROR: terraform init failed" >&2; return 1; }

  echo
  echo "[2/3] terraform apply"
  "$TF" apply -auto-approve -no-color \
    -var=vendor=hetzner \
    -var=vm_hostname="$VM_HOSTNAME" \
    -var=tailscale_auth_key="$TS_AUTH_KEY" \
    || { echo "ERROR: terraform apply failed" >&2; return 1; }
  unset TS_AUTH_KEY

  echo
  echo "[3/3] capture outputs + report"
  local IPV4 IPV6 STATUS
  IPV4="$("$TF" output -raw joppa_ipv4 2>/dev/null)"
  IPV6="$("$TF" output -raw joppa_ipv6 2>/dev/null)"
  STATUS="$("$TF" output -raw joppa_status 2>/dev/null)"

  echo
  echo "============================================="
  echo "  VM provisioned: $VM_HOSTNAME"
  echo "  IPv4:    $IPV4"
  echo "  IPv6:    $IPV6"
  echo "  Status:  $STATUS"
  echo "============================================="
  echo
  echo "cloud-init is now running on the VM (apt updates, tailscale install,"
  echo "dr-bootstrap clone). Provisioning-only — phase1 is driven by this wrapper."

  if [ "$orchestrate" = 0 ]; then
    echo
    echo "--no-orchestrate set; halting after provisioning."
    echo "Next steps (manual):"
    echo "  Watch boot:    ssh root@$IPV4 'cloud-init status --wait'"
    echo "  Then:          ssh root@$IPV4 'cd /opt/dr-bootstrap && bash bootstrap/setup.sh phase1'"
    if [ "$test_mode" = 1 ]; then
      echo
      echo "When done verifying:"
      echo "  ./uluhe switch hetzner --destroy"
    fi
    return 0
  fi

  # Default path: drive secrets-fetch + phase1 over SSH.
  if ! orchestrate_phase1 "$IPV4" "$VM_HOSTNAME" "$test_mode"; then
    echo
    echo "ERROR: orchestration failed. VM is still up at $IPV4." >&2
    echo "  Inspect:   ssh root@$IPV4" >&2
    echo "  Tear down: ./uluhe switch hetzner --destroy" >&2
    return 1
  fi
}

cmd_surge() {
  echo "uluhe surge — burst capacity quote"
  echo "  TODO: read price matrix, compute job × duration × vendor"
}

cmd_hold() {
  echo "uluhe --hold — cancel pending auto-failover"
  echo "  TODO: signal Lotor daemon to abort current failover plan"
