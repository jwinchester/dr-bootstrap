main() {
  case "${1:---help}" in
    status)  shift; cmd_status "$@" ;;
    switch)  shift; cmd_switch "$@" ;;
    surge)   shift; cmd_surge "$@" ;;
    --hold)  shift; cmd_hold "$@" ;;
    --help|-h)
      cat <<HELP
Usage: uluhe <subcommand> [args]

Subcommands:
  status                 Health check on current primary
  switch <vendor>        Failover to hetzner (only one wired so far)
    --test               Boot a throwaway VM end-to-end (provision + phase1)
    --destroy            Tear down whatever's in terraform state
    --yes                Skip confirmation prompts (DANGEROUS)
    --no-orchestrate     Stop after terraform apply; don't drive phase1 over SSH
                         (debugging escape hatch — default is to orchestrate)
  surge --job NAME --days N
                         Quote burst-capacity machine for a job
  --hold                 Cancel pending auto-failover (5min window)
HELP
      ;;
    *) echo "Unknown subcommand: $1" >&2; exit 1 ;;
  esac
}

main "$@"
